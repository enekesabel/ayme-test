{
  "compilerOptions": {
    "target": "ES2022",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node", "@playwright/test"]
  },
  "include": ["src", "tests", "playwright.config.ts", "tsup.config.ts"],
  "exclude": ["node_modules", "dist"]
}
