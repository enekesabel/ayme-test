{
  "name": "@ayde/test",
  "version": "0.1.0-beta.0",
  "description": "Ayde testing framework for Playwright - drop-in @playwright/test wrapper with POM utilities",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./primitives": {
      "import": {
        "types": "./dist/primitives/index.d.ts",
        "default": "./dist/primitives/index.js"
      },
      "require": {
        "types": "./dist/primitives/index.d.cts",
        "default": "./dist/primitives/index.cjs"
      }
    },
    "./reporter": {
      "import": {
        "types": "./dist/reporter.d.ts",
        "default": "./dist/reporter.js"
      },
      "require": {
        "types": "./dist/reporter.d.cts",
        "default": "./dist/reporter.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "playwright",
    "page-object-model",
    "pom",
    "testing",
    "e2e",
    "end-to-end",
    "automation",
    "ayde"
  ],
  "author": "Ayde",
  "license": "MIT",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/enekesabel/ayde-testing.git"
  },
  "bugs": {
    "url": "https://github.com/enekesabel/ayde-testing/issues"
  },
  "homepage": "https://github.com/enekesabel/ayde-testing#readme",
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.18.6",
    "eslint": "^8.57.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
