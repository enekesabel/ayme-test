{
  "name": "@qaide/test",
  "version": "0.1.0-beta.0",
  "description": "State-driven, semantic web UI and E2E testing. Playwright adapter included.",
  "type": "module",
  "exports": {
    "./primitives": {
      "import": {
        "types": "./dist/primitives/index.d.ts",
        "default": "./dist/primitives/index.js"
      },
      "require": {
        "types": "./dist/primitives/index.d.cts",
        "default": "./dist/primitives/index.cjs"
      }
    },
    "./pom-universal": {
      "import": {
        "types": "./dist/pom-universal/index.d.ts",
        "default": "./dist/pom-universal/index.js"
      },
      "require": {
        "types": "./dist/pom-universal/index.d.cts",
        "default": "./dist/pom-universal/index.cjs"
      }
    },
    "./playwright": {
      "import": {
        "types": "./dist/playwright/index.d.ts",
        "default": "./dist/playwright/index.js"
      },
      "require": {
        "types": "./dist/playwright/index.d.cts",
        "default": "./dist/playwright/index.cjs"
      }
    },
    "./playwright/reporter": {
      "import": {
        "types": "./dist/playwright/reporter.d.ts",
        "default": "./dist/playwright/reporter.js"
      },
      "require": {
        "types": "./dist/playwright/reporter.d.cts",
        "default": "./dist/playwright/reporter.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "testing",
    "e2e",
    "end-to-end",
    "state-driven",
    "semantic-testing",
    "page-object-model",
    "pom",
    "playwright",
    "automation",
    "web-testing",
    "qaide"
  ],
  "author": "qaide",
  "license": "MIT",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/enekesabel/qaide-testing.git"
  },
  "bugs": {
    "url": "https://github.com/enekesabel/qaide-testing/issues"
  },
  "homepage": "https://github.com/enekesabel/qaide-testing#readme",
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    }
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.18.6",
    "eslint": "^8.57.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
